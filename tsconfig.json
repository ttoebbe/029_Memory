{
"compilerOptions": {
    /* Language & target environment */
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],


    /* Modules & resolution */
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,


    /* Type checking */
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,


    /* Misc */
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}